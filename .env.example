# ─── Required ──────────────────────────────────────────────────────────────────

# Anthropic Claude API key — powers the AI advisor chat and weekly digest
ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional but recommended ──────────────────────────────────────────────────

# Neon PostgreSQL — enables task persistence, rule firing deduplication, digests
# Connect via Vercel Storage tab → Neon → Create Database (auto-populates this)
POSTGRES_URL=postgres://...

# Stripe — enables billing/subscription management
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Security ──────────────────────────────────────────────────────────────────

# Optional: bypass key for demo accounts (skips rate limits when sent in request body)
DEMO_BYPASS_KEY=

# Optional: override hourly AI query cap per IP (default: 30)
AI_HOURLY_LIMIT=30

# ─── Analytics ─────────────────────────────────────────────────────────────────

# PostHog — product analytics (https://posthog.com)
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── App ───────────────────────────────────────────────────────────────────────

# Set this to your production domain for correct Stripe redirect URLs
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
