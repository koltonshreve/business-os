{
  "functions": {
    "pages/api/**/*.ts": { "maxDuration": 120 }
  },
  "crons": [
    {
      "path": "/api/cron/digest",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/weekly",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/task-reminders",
      "schedule": "0 13 * * *"
    }
  ]
}
